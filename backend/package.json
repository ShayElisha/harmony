{
  "name": "harmonyai-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build && npm run bundle:vercel",
    "bundle:vercel": "esbuild ./dist/api/index.js --bundle --platform=node --format=cjs --packages=external --outfile=../api/nest-handler.cjs",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.3",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.12",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.12",
    "@nestjs/swagger": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "mongoose": "^9.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.12",
    "@types/node": "^22.10.5",
    "@types/passport-jwt": "^4.0.1",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
